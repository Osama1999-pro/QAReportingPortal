# Environment
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_string
JWT_RESET_SECRET=change_this_reset_secret_too

# App URL (use localhost locally, your Vercel URL in production)
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:5000

# Optional email (password reset)
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_NAME=QA Portal
